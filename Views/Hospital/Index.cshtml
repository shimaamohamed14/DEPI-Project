@model Life_Artery1.Models.Hospital
@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    ViewData["Title"] = "Hospital";
}

<div class="dashboard-layout">
  <aside class="sidebar">
    <div class="sidebar-brand">Hospital, @Model.Name</div>
    <nav class="sidebar-nav">
      <div class="sidebar-label" data-i18n="sb_search_req">Search & Request</div>
      <a href="#availability" class="sidebar-link active"><i class="bi bi-grid-3x3-gap-fill"></i> <span data-i18n="sb_availability">Blood Availability</span></a>
      <a href="#new-request" class="sidebar-link"><i class="bi bi-plus-circle"></i> <span data-i18n="sb_new_req">New Request</span></a>
      <div class="sidebar-label" data-i18n="sb_my_req">My Requests</div>
      <a href="#my-requests" class="sidebar-link"><i class="bi bi-list-check"></i> <span data-i18n="sb_history">Request History</span></a>
      <div class="sidebar-label" data-i18n="sb_settings">Settings</div>
      <a href="/Hospital/HospitalInfo" class="sidebar-link"><i class="bi bi-info-circle"></i> <span data-i18n="sb_hospital_info">Hospital Info</span></a>
    </nav>
    <div style="margin-top:auto;padding-top:1rem;border-top:1px solid rgba(255,255,255,0.08);">
      <div style="font-size:0.78rem;color:rgba(255,255,255,0.3);">@Model.Name</div>
      <div style="font-size:0.72rem;color:rgba(255,255,255,0.2);">@Model.City - @Model.Governorate</div>
    </div>
  </aside>

  <main class="dashboard-main">
    <div class="dash-header">
      <h1 class="dash-title" data-i18n="h_dash_title">Hospital Dashboard</h1>
      <p class="dash-subtitle" data-i18n="h_dash_sub">Check blood availability, send requests, and track your orders.</p>
    </div>

    <div class="row g-3 mb-4">
      <div class="col-6 col-lg-3">
        <div class="dash-stat-card">
          <div class="dash-stat-icon icon-red"><i class="bi bi-droplet-fill text-danger"></i></div>
          <div class="dash-stat-value" id="hAvailTypes">0</div>
          <div class="dash-stat-label" data-i18n="h_avail">Available Types</div>
        </div>
      </div>
      <div class="col-6 col-lg-3">
        <div class="dash-stat-card">
          <div class="dash-stat-icon icon-orange"><i class="bi bi-hourglass-split" style="color:#E67E22"></i></div>
          <div class="dash-stat-value" id="hPendingReqs">0</div>
          <div class="dash-stat-label" data-i18n="h_pending">Pending Requests</div>
        </div>
      </div>
      <div class="col-6 col-lg-3">
        <div class="dash-stat-card">
          <div class="dash-stat-icon icon-green"><i class="bi bi-check-circle-fill" style="color:#27AE60"></i></div>
          <div class="dash-stat-value" id="hApprovedReqs">0</div>
          <div class="dash-stat-label" data-i18n="h_approved">Approved</div>
        </div>
      </div>
      <div class="col-6 col-lg-3">
        <div class="dash-stat-card">
          <div class="dash-stat-icon icon-blue"><i class="bi bi-file-text-fill" style="color:#2980B9"></i></div>
          <div class="dash-stat-value" id="hTotalReqs">0</div>
          <div class="dash-stat-label" data-i18n="h_total">Total Requests</div>
        </div>
      </div>
    </div>

    <div id="availability" class="dash-table-card mb-4">
      <div class="dash-table-title" data-i18n="h_avail_title">Blood Availability Search</div>
      <div style="padding:0 1.5rem 1.5rem;">
        <div class="row g-3 align-items-end">
          <div class="col-md-6">
            <label class="dash-label" data-i18n="search_label">Blood Type</label>
            <select class="dash-select" id="hospAvailBloodType" onchange="fetchHospitalBloodAvailability()">
              <option value="">Select Blood Type</option>
              <option value="A+">A+</option><option value="A-">A−</option>
              <option value="B+">B+</option><option value="B-">B−</option>
              <option value="O+">O+</option><option value="O-">O−</option>
              <option value="AB+">AB+</option><option value="AB-">AB−</option>
            </select>
          </div>
          <div class="col-md-3">
            <button class="btn-dash w-100" onclick="fetchHospitalBloodAvailability()"><i class="bi bi-search"></i> <span data-i18n="search_btn">Search</span></button>
          </div>
        </div>
      </div>
      <div class="row g-3" id="availableBloodGrid" style="padding:0 1.5rem 1.5rem;">
        <div class="col-12" style="text-align:center;color:var(--mid-gray);padding:2rem;" data-i18n="h_select_type">Select a blood type to see available sources.</div>
      </div>
    </div>

    <div id="new-request" class="dash-table-card mb-4">
      <div class="dash-table-title" data-i18n="h_req_form_title">Send Blood Request</div>
      <form onsubmit="addHospitalRequest(event)">
        <div class="row g-3" style="padding:0 1.5rem 1.5rem;">
          <div class="col-md-3">
            <label class="dash-label" data-i18n="h_type_label">Blood Type Needed</label>
            <select class="dash-select" id="requestBloodType">
              <option>Select Blood Type</option>
              <option value="A+">A+</option><option value="A-">A−</option>
              <option value="B+">B+</option><option value="B-">B−</option>
              <option value="O+">O+</option><option value="O-">O−</option>
              <option value="AB+">AB+</option><option value="AB-">AB−</option>
            </select>
          </div>
          <div class="col-md-3">
            <label class="dash-label" data-i18n="h_bank_label">Select Blood Bank</label>
            <select class="dash-select" id="requestBloodBank">
              <option value="">Select Blood Bank</option>
            </select>
          </div>
          <div class="col-md-3">
            <label class="dash-label" data-i18n="h_qty_label">Number of Units</label>
            <input type="number" class="dash-input" id="requestQuantity" placeholder="e.g. 5" min="1">
          </div>
          <div class="col-md-3 d-flex align-items-end">
            <button type="submit" class="btn-dash w-100"><i class="bi bi-send"></i> <span data-i18n="h_send_btn">Send Request</span></button>
          </div>
        </div>
      </form>
    </div>

    <div id="my-requests" class="dash-table-card">
      <div class="dash-table-title" data-i18n="h_history_title">My Request History</div>
      <table class="custom-table">
        <thead>
          <tr>
            <th data-i18n="h_col_type">Blood Type</th>
            <th data-i18n="h_col_qty">Quantity</th>
            <th data-i18n="h_col_bank">Blood Bank Name</th>
            <th data-i18n="h_col_date">Date Sent</th>
            <th data-i18n="h_col_status">Status</th>
          </tr>
        </thead>
        <tbody id="hospitalRequestsTable">
          <tr><td colspan="5" style="text-align:center;color:var(--mid-gray);padding:2rem;" data-i18n="no_requests">No requests yet.</td></tr>
        </tbody>
      </table>
    </div>
  </main>
</div>

<script>
fetchHospitalData();
</script>
