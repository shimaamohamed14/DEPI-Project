@{
    ViewData["Title"] = "Search Blood";
}

<!-- Search Hero -->
<section class="search-hero">
  <div class="container" style="position:relative;z-index:2;">
    <div class="hero-badge mx-auto" style="width:fit-content;margin-bottom:1.5rem;" data-i18n="search_badge">🔍 No login required</div>
    <h2 style="font-family:'Playfair Display',serif;font-size:clamp(2rem,5vw,3.2rem);font-weight:900;color:#fff;margin-bottom:0.5rem;" data-i18n="search_title">Find Blood — Right Now</h2>
    <p style="color:rgba(255,255,255,0.55);margin-bottom:2rem;font-weight:300;" data-i18n="search_sub">Select a blood type to see all available sources near you.</p>

    <div class="search-box-container">
      <form id="searchForm">
        <div class="row g-3 align-items-end">
          <div class="col-md-7">
            <label style="font-size:0.78rem;text-transform:uppercase;letter-spacing:1px;color:rgba(255,255,255,0.5);font-weight:600;display:block;margin-bottom:8px;" data-i18n="search_label">Blood Type</label>
            <select class="custom-select" id="bloodType">
              <option>Select Blood Type</option>
              <option value="A+">A+ (A Positive)</option>
              <option value="A-">A− (A Negative)</option>
              <option value="B+">B+ (B Positive)</option>
              <option value="B-">B− (B Negative)</option>
              <option value="O+">O+ (O Positive)</option>
              <option value="O-">O− (O Negative)</option>
              <option value="AB+">AB+ (AB Positive)</option>
              <option value="AB-">AB− (AB Negative)</option>
            </select>
          </div>
          <div class="col-md-5">
            <button type="submit" class="btn-primary-custom w-100" style="justify-content:center;padding:14px 24px;">
              <i class="bi bi-search"></i> <span data-i18n="search_btn">Search Now</span>
            </button>
          </div>
        </div>
      </form>
      <div style="border-top:1px solid rgba(255,255,255,0.1);margin-top:1.5rem;padding-top:1rem;display:flex;gap:1.5rem;flex-wrap:wrap;justify-content:center;">
        <span style="font-size:0.78rem;color:rgba(255,255,255,0.4);" data-i18n="search_quick">Quick select:</span>
        <div style="display:flex;gap:8px;flex-wrap:wrap;justify-content:center;">
          <button onclick="quickSearch('A+')" class="quick-btn">A+</button>
          <button onclick="quickSearch('O+')" class="quick-btn">O+</button>
          <button onclick="quickSearch('B+')" class="quick-btn">B+</button>
          <button onclick="quickSearch('O-')" class="quick-btn">O−</button>
          <button onclick="quickSearch('AB+')" class="quick-btn">AB+</button>
          <button onclick="quickSearch('AB-')" class="quick-btn">AB−</button>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
.quick-btn { background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.15);color:rgba(255,255,255,0.7);padding:5px 14px;border-radius:100px;font-size:0.82rem;font-family:'DM Sans',sans-serif;font-weight:600;cursor:pointer;transition:all 0.2s; }
.quick-btn:hover { background:rgba(192,57,43,0.3);border-color:rgba(192,57,43,0.5);color:#fff; }
</style>

<!-- Results -->
<section class="py-5" style="background:var(--off-white);min-height:50vh;">
  <div class="container">
    <div id="searchResults">
      <div class="text-center py-5" data-search-default style="color:var(--mid-gray);">
        <div style="font-size:4rem;margin-bottom:1rem;">🩸</div>
        <div style="font-family:'Playfair Display',serif;font-size:1.5rem;font-weight:700;color:var(--dark);margin-bottom:0.5rem;" data-i18n="search_default_title">Search for a Blood Type</div>
        <div style="font-weight:300;" data-i18n="search_default_sub">Select a blood type above to find all available sources.</div>
      </div>
    </div>
  </div>
</section>

<!-- Emergency Note -->
<section style="background:linear-gradient(135deg,var(--blood),var(--crimson));padding:50px 0;">
  <div class="container text-center">
    <h3 style="font-family:'Playfair Display',serif;color:#fff;font-weight:700;margin-bottom:0.5rem;" data-i18n="emergency_title">🚨 In a Life-Threatening Emergency?</h3>
    <p style="color:rgba(255,255,255,0.7);font-weight:300;margin-bottom:1.5rem;" data-i18n="emergency_sub">Call Egypt's National Blood Hotline or Emergency Services immediately.</p>
    <div class="d-flex gap-3 justify-content-center flex-wrap">
      <a href="tel:123" class="btn-outline-custom" style="font-size:1rem;"><i class="bi bi-telephone-fill"></i> <span data-i18n="emergency_btn1">Call 123 — Ambulance</span></a>
      <a href="tel:01116474444" class="btn-primary-custom" style="background:rgba(255,255,255,0.15);font-size:1rem;"><i class="bi bi-droplet-fill"></i> <span data-i18n="emergency_btn2">0111-647-4444 Blood Hotline</span></a>
    </div>
  </div>
</section>


<script>
function quickSearch(type) {
  document.getElementById('bloodType').value = type;
  document.getElementById('searchForm').dispatchEvent(new Event('submit'));
}
</script>
