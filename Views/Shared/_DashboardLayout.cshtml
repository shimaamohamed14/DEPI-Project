<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Life Artery</title>
    <link rel="icon" href="~/images/laicon1.png">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/style.css">
</head>
<body>

    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg">
        <div class="container">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">Life Artery</a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse justify-content-end" id="navbarNav">
                <ul class="navbar-nav gap-1 align-items-center">

                    <li class="nav-item">
                        <a class="nav-link active" asp-controller="Home" asp-action="Index" data-i18n="nav_home">Home</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="About" data-i18n="nav_about">About</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Search" data-i18n="nav_search">Search Blood</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Contact" data-i18n="nav_contact">Contact</a>
                    </li>

                    @if (User.Identity.IsAuthenticated)
                    {
                        var role = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value;
                        var dashboardAction = role switch
                        {
                            "Admin" => "/Admin/Index",
                            "Hospital" => "/Hospital/Index",
                            "BloodBank" => "/BloodBank/Index",
                            _ => "/Home/Index"
                        };
                        <li class="nav-item ms-1">
                            <a class="nav-link nav-signin-btn" href="@dashboardAction" data-i18n="nav_dashboard">Dashboard</a>
                        </li>
                        <li class="nav-item ms-1">
                            <a class="nav-link nav-signup-btn" asp-controller="Account" asp-action="Logout" data-i18n="nav_logout">Logout</a>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item ms-1">
                            <a class="nav-link nav-signin-btn" asp-controller="Account" asp-action="Login" data-i18n="nav_signin">Sign In</a>
                        </li>
                        <li class="nav-item ms-1">
                            <a class="nav-link nav-signup-btn" asp-controller="Account" asp-action="Login" asp-fragment="signup" data-i18n="nav_signup">Sign Up</a>
                        </li>
                    }

                    <li class="nav-item ms-2">
                        <button class="lang-toggle-btn" onclick="toggleLanguage()">العربية</button>
                    </li>

                </ul>
            </div>
        </div>
    </nav>
    
    
            @RenderBody()


    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/main.js"></script>
</body>
</html>
