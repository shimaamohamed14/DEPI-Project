@model Life_Artery1.ViewModels.HospitalRegisterViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Hospital Registration – Life Artery</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/style.css">
</head>
<body>
    <div class="auth-bg"></div>
    <div class="auth-gradient"></div>
    <div class="decor-drop" style="width:180px;height:180px;top:8%;left:4%;transform:rotate(-45deg);"></div>
    <div class="decor-drop" style="width:110px;height:110px;bottom:12%;right:6%;transform:rotate(135deg);"></div>
    <div class="decor-drop" style="width:70px;height:70px;top:42%;right:18%;transform:rotate(-20deg);"></div>

    <!-- NAV -->
    <nav class="auth-nav">
        <a asp-controller="Home" asp-action="Index" class="auth-nav-brand">🩸 Life Artery</a>
        <div class="nav-actions">
            <a asp-controller="Home" asp-action="Index" class="nav-back"><i class="bi bi-arrow-left"></i> <span id="txt-back">Back to Home</span></a>
            <button class="lang-toggle" onclick="toggleLang()"><i class="bi bi-translate"></i><span id="langLabel">العربية</span></button>
        </div>
    </nav>

    <div class="auth-wrapper">
        <div class="auth-card" id="authCard">

            <!-- TABS -->
            <div class="auth-tabs">
                <button class="auth-tab active"><span id="txt-tab-signup">Sign Up</span></button>
            </div>

            <div class="auth-panel active" id="panelSignup">
                <!-- HOSPITAL FORM -->
                <div id="formHospital">
                    <div class="step-progress"><div class="step-fill" style="width:100%"></div></div>
                    <div class="card-brand" style="margin-bottom:14px;">
                        <div class="card-brand-icon">🏥</div>
                        <div class="card-brand-title" id="txt-hosp-title">Hospital Registration</div>
                        <div class="card-brand-sub" id="txt-hosp-sub">Official facility information</div>
                    </div>
                    <div class="auth-alert error" id="hospAlert"><i class="bi bi-exclamation-circle-fill"></i><span id="hospAlertMsg"></span></div>
                    <div class="auth-alert success" id="hospSuccess"><i class="bi bi-check-circle-fill"></i><span id="txt-reg-ok-hosp">Account created! Redirecting…</span></div>
                    <form asp-action="HospitalRegister" asp-controller="Account" method="post" enctype="multipart/form-data">
                        <div asp-validation-summary="All" class="text-danger"></div>
                        <div class="form-section-label" id="txt-hosp-sec1">Facility Information</div>
                        <div class="row g-2">
                            <div class="col-12">
                                <div class="auth-field">
                                    <label class="auth-label" id="txt-hospname-lbl">Hospital Name</label>
                                    <input asp-for="Name" class="auth-input" placeholder="Cairo Medical Center" />
                                    <span asp-validation-for="Name" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="auth-field">
                                    <label class="auth-label" id="txt-hosplicense-lbl">License Number</label>
                                    <input asp-for="LicenseNumber" class="auth-input" placeholder="HOSP-2024-XXXXX" />
                                    <span asp-validation-for="LicenseNumber" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="auth-field">
                                    <label class="auth-label" id="txt-hospissuer-lbl">Issuing Authority</label>
                                    <select asp-for="IssuingAuthority" class="auth-select">
                                        <option value="" disabled selected>Select…</option>
                                        <option value="MOH">Ministry of Health</option>
                                        <option value="HIO">Health Insurance Org.</option>
                                        <option value="Other">Other</option>
                                    </select>
                                    <span asp-validation-for="IssuingAuthority" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-12">
                                <div class="auth-field">
                                    <label class="auth-label" id="txt-hosplicfile-lbl">License Document (PDF / Image)</label>
                                    <div class="file-wrap" onclick="document.getElementById('hospLicFile').click()">
                                        <i class="bi bi-file-earmark-arrow-up file-icon"></i>
                                        <label class="file-lbl" id="hospLicFileLabel">Click to upload…</label>
                                        <input asp-for="LicenseDocument"
                                            type="file"
                                            id="hospLicFile"
                                            accept=".pdf,.jpg,.jpeg,.png"
                                            onchange="updateFileLabel(this,'hospLicFileLabel')" />                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="form-section-label" id="txt-hosp-sec2">Location & Contact</div>
                        <div class="row g-2">
                            <div class="col-md-6">
                                <div class="auth-field">
                                    <label class="auth-label" id="txt-hospgov-lbl">Governorate</label>
                                    <input asp-for="Governorate" class="auth-input" placeholder="Cairo" />
                                    <span asp-validation-for="Governorate" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="auth-field">
                                    <label class="auth-label" id="txt-hospcity-lbl">City / District</label>
                                    <input asp-for="City" class="auth-input" placeholder="Heliopolis" />
                                    <span asp-validation-for="City" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-12">
                                <div class="auth-field">
                                    <label class="auth-label" id="txt-hospstreet-lbl">Street Address</label>
                                    <input asp-for="Address" class="auth-input" placeholder="22 Salah Salem St." />
                                    <span asp-validation-for="Address" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="auth-field">
                                    <label class="auth-label" id="txt-hospphone-lbl">Official Phone</label>
                                    <input asp-for="PhoneNumber" class="auth-input" placeholder="02XXXXXXXX" />
                                    <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="auth-field">
                                    <label class="auth-label" id="txt-hospemail-lbl">Official Email</label>
                                    <input asp-for="Email" class="auth-input" placeholder="info@hospital.eg" />
                                    <span asp-validation-for="Email" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-12">
                                <div class="auth-field">
                                    <label class="auth-label" id="txt-hospgps-lbl">GPS / Google Maps Link</label>
                                    <input asp-for="GoogleMapsLink" class="auth-input" placeholder="30.0444° N, 31.2357° E" />
                                    <span asp-validation-for="GoogleMapsLink" class="text-danger"></span>
                                </div>
                            </div>
                        </div>
                        <div class="form-section-label" id="txt-hosp-sec3">Facility Details</div>
                        <div class="row g-2">
                            <div class="col-12">
                                <div class="auth-field">
                                    <label class="auth-label" id="txt-hospmeddir-lbl">Medical Director Name</label>
                                    <input asp-for="MedicalDirectorName" class="auth-input" placeholder="Dr. Mohamed Kamal" />
                                    <span asp-validation-for="MedicalDirectorName" class="text-danger"></span>
                                </div>
                            </div>
                        </div>
                        <div class="form-section-label">Account Information</div>
                        <div class="auth-field">
                            <label class="auth-label">Account Owner Name</label>
                            <input asp-for="FullName" class="auth-input" placeholder="Ahmed Mohamed" />
                            <span asp-validation-for="FullName" class="text-danger"></span>
                        </div>
                        <div class="form-section-label" id="txt-hosp-sec4">Account Security</div>
                        <div class="auth-field">
                            <label class="auth-label" id="txt-hosp-pass-lbl">Password</label>
                            <div class="input-group-auth">
                                <input asp-for="Password" type="password" class="auth-input" placeholder="Min. 8 characters" id="hospPass" />                                <button type="button" class="toggle-pass" onclick="togglePass('hospPass',this)"><i class="bi bi-eye-slash"></i></button>
                            </div>
                            <span asp-validation-for="Password" class="text-danger"></span>
                        </div>
                        <div class="auth-field">
                            <label class="auth-label" id="txt-hosp-pass-confirm-lbl">Confirm Password</label>
                            <div class="input-group-auth">
                                <input asp-for="ConfirmPassword" type="password" class="auth-input" placeholder="Repeat password" id="hospPassConfirm" />                                <button type="button" class="toggle-pass" onclick="togglePass('hospPassConfirm',this)"><i class="bi bi-eye-slash"></i></button>
                            </div>
                            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                        </div>
                        <button type="submit" class="auth-btn" id="txt-hosp-register-btn">Register Hospital →</button>
                        <button type="button" class="auth-btn-outline" onclick="window.location.href='/Account/Register'" id="txt-hosp-back-role">← Change Role</button>
                    </form>
                </div>
            </div><!-- /panelSignup -->

        </div><!-- /auth-card -->
    </div><!-- /auth-wrapper -->
    <script src="~/js/main.js"></script>
    <partial name="_ValidationScriptsPartial" />
</body>
</html>
