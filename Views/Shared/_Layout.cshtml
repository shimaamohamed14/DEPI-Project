<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Life Artery</title>
    <link rel="icon" href="~/images/laicon1.png">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/style.css">
</head>
<body>

    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg">
        <div class="container">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">Life Artery</a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse justify-content-end" id="navbarNav">
                <ul class="navbar-nav gap-1 align-items-center">

                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active" : "")"
                           asp-controller="Home"
                           asp-action="Index"
                           data-i18n="nav_home">
                            Home
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "About" ? "active" : "")"
                           asp-controller="Home"
                           asp-action="About"
                           data-i18n="nav_about">
                            About
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Search" ? "active" : "")"
                           asp-controller="Home"
                           asp-action="Search"
                           data-i18n="nav_search">
                            Search Blood
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Contact" ? "active" : "")"
                           asp-controller="Home"
                           asp-action="Contact"
                           data-i18n="nav_contact">
                            Contact
                        </a>
                    </li>

                    @if (User.Identity.IsAuthenticated)
                    {
                        var role = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value;
                        var dashboardAction = role switch
                        {
                            "Admin" => "/Admin/Index",
                            "Hospital" => "/Hospital/Index",
                            "BloodBank" => "/BloodBank/Index",
                            _ => "/Home/Index"
                        };
                        <li class="nav-item ms-1">
                            <a class="nav-link nav-signin-btn" href="@dashboardAction" data-i18n="nav_dashboard">Dashboard</a>
                        </li>
                        <li class="nav-item ms-1">
                            <a class="nav-link nav-signup-btn" asp-controller="Account" asp-action="Logout" data-i18n="nav_logout">Logout</a>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item ms-1">
                            <a class="nav-link nav-signin-btn" asp-controller="Account" asp-action="Login" data-i18n="nav_signin">Sign In</a>
                        </li>
                        <li class="nav-item ms-1">
                            <a class="nav-link nav-signup-btn" asp-controller="Account" asp-action="Register" data-i18n="nav_signup">Sign Up</a>
                        </li>
                    }

                    <li class="nav-item ms-2">
                        <button class="lang-toggle-btn" onclick="toggleLanguage()">العربية</button>
                    </li>

                </ul>
            </div>
        </div>
    </nav>
    
    
            @RenderBody()



    <!-- Footer -->
    <footer class="main-footer">
        <div class="container">
            <div class="row g-5">
                <div class="col-lg-4">
                    <div class="footer-brand"> Life Artery</div>
                    <p class="footer-desc" data-i18n="footer_desc">A centralized network connecting hospitals and blood banks across Egypt to eliminate delays and save lives in critical moments.</p>
                    <div style="font-size:0.78rem;color:rgba(255,255,255,0.3);margin-bottom:8px;" data-i18n="footer_social_msg">Official Life Artery channels coming soon.</div>
                    <div class="footer-social mt-1">
                        <span style="cursor:default;opacity:0.5;"><i class="bi bi-facebook"></i></span>
                        <span style="cursor:default;opacity:0.5;"><i class="bi bi-twitter-x"></i></span>
                        <span style="cursor:default;opacity:0.5;"><i class="bi bi-instagram"></i></span>
                        <span style="cursor:default;opacity:0.5;"><i class="bi bi-linkedin"></i></span>
                    </div>
                </div>
                <div class="col-6 col-lg-2">
                    <div class="footer-heading" data-i18n="footer_nav">Navigate</div>
                    <a class="footer-link" asp-controller="Home" asp-action="Index">Home</a>

                    <a class="footer-link" asp-controller="Home" asp-action="About">About</a>

                    <a class="footer-link" asp-controller="Home" asp-action="Search">Search Blood</a>
                    <a class="footer-link" asp-controller="Home" asp-action="Contact">Contact</a>
                </div>
                <div class="col-6 col-lg-2">
                    <div class="footer-heading" data-i18n="footer_dashboards">Dashboards</div>
                    <a class="footer-link" asp-controller="BloodBank" asp-action="Index">Blood Bank</a>
                    <a class="footer-link" asp-controller="Hospital" asp-action="Index">Hospital</a>
                    <a class="footer-link" asp-controller="Admin" asp-action="Index">Admin</a>
                </div>
                <div class="col-lg-4">
                    <div class="footer-heading" data-i18n="footer_emergency">Emergency Contacts</div>
                    <a class="footer-link" href="tel:123"> Ambulance: 123</a>
                    <a class="footer-link" href="tel:01116474444"> Blood Hotline: 0111-647-4444</a>
                    <a class="footer-link" href="mailto:lifearterysupport@gmail.com"> lifearterysupport@gmail.com</a>
                </div>
            </div>
            <div class="footer-bottom d-flex justify-content-between flex-wrap gap-2">
                <span data-i18n="footer_copy"> 2026 Life Artery. All Rights Reserved.</span>
                <span data-i18n="footer_made">Designed with  to save lives.</span>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/main.js"></script>
</body>
</html>
