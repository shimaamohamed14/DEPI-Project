@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sign Up – Life Artery</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/style.css">
</head>
<body>
    <div class="auth-bg"></div>
    <div class="auth-gradient"></div>
    <div class="decor-drop" style="width:180px;height:180px;top:8%;left:4%;transform:rotate(-45deg);"></div>
    <div class="decor-drop" style="width:110px;height:110px;bottom:12%;right:6%;transform:rotate(135deg);"></div>
    <div class="decor-drop" style="width:70px;height:70px;top:42%;right:18%;transform:rotate(-20deg);"></div>

    <!-- NAV -->
    <nav class="auth-nav">
        <a asp-controller="Home" asp-action="Index" class="auth-nav-brand">🩸 Life Artery</a>
        <div class="nav-actions">
            <a asp-controller="Home" asp-action="Index" class="nav-back"><i class="bi bi-arrow-left"></i> <span id="txt-back">Back to Home</span></a>
            <button class="lang-toggle" onclick="toggleLang()"><i class="bi bi-translate"></i><span id="langLabel">العربية</span></button>
        </div>
    </nav>

    <div class="auth-wrapper">
        <div class="auth-card" id="authCard">

            <!-- TABS -->
            <div class="auth-tabs">
                <button class="auth-tab active" id="tabSignUp"><span id="txt-tab-signup">Sign Up</span></button>
            </div>

            <!-- STEP 1: Role picker -->
            <div class="auth-panel active" id="panelSignup">
                <div id="stepRole">
                    <div class="card-brand">
                        <div class="card-brand-icon">🩸</div>
                        <div class="card-brand-title" id="txt-create">Create Account</div>
                        <div class="card-brand-sub" id="txt-create-sub">Who are you registering as?</div>
                    </div>
                    <div class="auth-alert error" id="roleAlert"><i class="bi bi-exclamation-circle-fill"></i><span id="roleAlertMsg"></span></div>
                    <div class="role-grid">
                        <div class="role-card" data-role="Hospital" onclick="selectRole(this)">
                            <span class="role-check"><i class="bi bi-check-lg"></i></span>
                            <span class="role-icon">🏥</span>
                            <div class="role-name" id="txt-role-hospital">Hospital</div>
                            <div class="role-desc" id="txt-role-hospital-desc">Medical facility</div>
                        </div>
                        <div class="role-card" data-role="BloodBank" onclick="selectRole(this)">
                            <span class="role-check"><i class="bi bi-check-lg"></i></span>
                            <span class="role-icon">🩸</span>
                            <div class="role-name" id="txt-role-bank">Blood Bank</div>
                            <div class="role-desc" id="txt-role-bank-desc">Blood storage center</div>
                        </div>

                    </div>
                    <button class="auth-btn" onclick="goToForm()" style="margin-top:16px;" id="txt-next-btn">Next →</button>
                    <div class="auth-switch"><span id="txt-has-acc">Already have an account?</span> <a asp-controller="Account" asp-action="Login" id="txt-go-signin">Sign In</a></div>
                </div>
            </div><!-- /panelSignup -->

        </div><!-- /auth-card -->
    </div><!-- /auth-wrapper -->

    <script src="~/js/main.js"></script>
   
</body>
</html>
