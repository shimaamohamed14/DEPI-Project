@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    ViewData["Title"] = "User Details";
}

<div class="dashboard-layout">
  <aside class="sidebar">
    <div class="sidebar-brand">Admin, @User.FindFirst("EntityName")?.Value</div>
    <nav class="sidebar-nav">
      <div class="sidebar-label" data-i18n="sb_overview">Overview</div>
      <a href="/Admin/Index" class="sidebar-link"><i class="bi bi-arrow-left"></i> <span data-i18n="sb_back">Back to Dashboard</span></a>
    </nav>
  </aside>

  <main class="dashboard-main">
    <div class="dash-header">
      <h1 class="dash-title">@ViewBag.FullName</h1>
      <p class="dash-subtitle">@ViewBag.RoleLabel <span data-i18n="@(ViewBag.UserRole == "Admin" ? "dtl_account_word" : "dtl_reg_details")">@(ViewBag.UserRole == "Admin" ? "Account" : "Registration Details")</span></p>
    </div>

    <div class="dash-table-card mb-4">
      <div class="row g-4" style="padding:1.5rem;">
        <div class="col-md-6">
          <div class="feature-card" style="padding:1.5rem;">
            <h5 style="font-family:'Playfair Display',serif;font-weight:700;margin-bottom:1rem;color:var(--blood);">
              @if (ViewBag.UserRole == "Hospital") { <i class="bi bi-hospital"></i> }
              else if (ViewBag.UserRole == "BloodBank") { <i class="bi bi-droplet"></i> }
              else { <i class="bi bi-person-badge"></i> }
              <span data-i18n="acct_info_section">Account Information</span>
            </h5>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
              <div><strong data-i18n="dtl_full_name">Full Name:</strong><br><span style="color:var(--mid-gray);font-size:0.9rem;">@ViewBag.FullName</span></div>
              <div><strong data-i18n="dtl_email">Email:</strong><br><span style="color:var(--mid-gray);font-size:0.9rem;">@ViewBag.UserEmail</span></div>
              @if (ViewBag.Phone != null)
              {
                <div><strong data-i18n="dtl_phone">Phone:</strong><br><span style="color:var(--mid-gray);font-size:0.9rem;">@ViewBag.Phone</span></div>
              }
              <div><strong data-i18n="dtl_role">Role:</strong><br><span style="color:var(--mid-gray);font-size:0.9rem;">@ViewBag.UserRole</span></div>
              <div><strong data-i18n="dtl_reg_date">Registration Date:</strong><br><span style="color:var(--mid-gray);font-size:0.9rem;">@ViewBag.RegisteredDate.ToString("dd MMM yyyy")<br>@ViewBag.RegisteredDate.ToString("hh:mm tt")</span></div>
              <div><strong data-i18n="dtl_status">Status:</strong><br>
                @if (ViewBag.IsApproved)
                {
                  <span class="badge bg-success" data-i18n="dtl_approved">Approved ✓</span>
                }
                else
                {
                  <span class="badge bg-warning text-dark" data-i18n="status_pending">Pending</span>
                }
              </div>
            </div>
          </div>
        </div>

        @if (ViewBag.UserRole == "Hospital" || ViewBag.UserRole == "BloodBank")
        {
          <div class="col-md-6">
            <div class="feature-card" style="padding:1.5rem;">
              <h5 style="font-family:'Playfair Display',serif;font-weight:700;margin-bottom:1rem;color:var(--blood);">
                @if (ViewBag.UserRole == "Hospital") { <i class="bi bi-hospital"></i> }
                else { <i class="bi bi-droplet"></i> }
                @ViewBag.RoleLabel <span data-i18n="dtl_information_word">Information</span>
              </h5>
              <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
                <div><strong data-i18n="@(ViewBag.UserRole == "Hospital" ? "dtl_hosp_name" : "dtl_bb_name")">@(ViewBag.UserRole == "Hospital" ? "Hospital Name:" : "Blood Bank Name:")</strong><br><span style="color:var(--mid-gray);font-size:0.9rem;">@ViewBag.EntityName</span></div>
                <div><strong data-i18n="dtl_license_num">License Number:</strong><br><span style="color:var(--mid-gray);font-size:0.9rem;">@ViewBag.LicenseNumber</span></div>
                <div><strong data-i18n="dtl_issuer">Issuing Authority:</strong><br><span style="color:var(--mid-gray);font-size:0.9rem;">@ViewBag.IssuingAuthority</span></div>
                <div><strong data-i18n="dtl_governorate">Governorate:</strong><br><span style="color:var(--mid-gray);font-size:0.9rem;">@ViewBag.Governorate</span></div>
                <div><strong data-i18n="dtl_city">City:</strong><br><span style="color:var(--mid-gray);font-size:0.9rem;">@ViewBag.City</span></div>
                <div><strong data-i18n="dtl_address">Address:</strong><br><span style="color:var(--mid-gray);font-size:0.9rem;">@ViewBag.Address</span></div>
                <div><strong data-i18n="dtl_phone">Phone:</strong><br><span style="color:var(--mid-gray);font-size:0.9rem;">@ViewBag.Phone</span></div>
                <div><strong data-i18n="dtl_email">Email:</strong><br><span style="color:var(--mid-gray);font-size:0.9rem;">@ViewBag.Email</span></div>
                @if (!string.IsNullOrEmpty(ViewBag.GoogleMapsLink))
                {
                  <div style="grid-column:span 2;"><strong data-i18n="dtl_maps">Google Maps:</strong><br><a href="@ViewBag.GoogleMapsLink" target="_blank" style="color:var(--blood);font-size:0.9rem;">@ViewBag.GoogleMapsLink</a></div>
                }
                <div><strong data-i18n="@(ViewBag.UserRole == "Hospital" ? "dtl_med_director" : "dtl_manager")">@(ViewBag.UserRole == "Hospital" ? "Medical Director:" : "Manager:")</strong><br><span style="color:var(--mid-gray);font-size:0.9rem;">@ViewBag.DirectorName</span></div>
                @if (!string.IsNullOrEmpty(ViewBag.LicenseDocument))
                {
                  <div><strong data-i18n="dtl_license_doc">License Document:</strong><br><a href="@ViewBag.LicenseDocument" target="_blank" style="color:var(--blood);font-size:0.9rem;"><i class="bi bi-file-earmark"></i> <span data-i18n="dtl_view_license_doc">View License Document</span></a></div>
                }
              </div>
            </div>
          </div>
        }
      </div>

      @if (!ViewBag.IsApproved)
      {
        <div style="padding:1.5rem;display:flex;gap:12px;">
          <form asp-action="Approve" asp-controller="Admin" method="post">
            <input type="hidden" name="id" value="@ViewBag.UserId" />
            <button type="submit" class="btn-dash" style="background:#27AE60;color:#fff;border:none;padding:10px 24px;border-radius:8px;font-weight:600;"><i class="bi bi-check-circle"></i> <span data-i18n="approve_btn">Approve</span></button>
          </form>
          <form asp-action="Reject" asp-controller="Admin" method="post" onsubmit="return confirm(t('confirm_reject'))">
            <input type="hidden" name="id" value="@ViewBag.UserId" />
            <button type="submit" class="btn-dash" style="background:#C0392B;color:#fff;border:none;padding:10px 24px;border-radius:8px;font-weight:600;"><i class="bi bi-x-circle"></i> <span data-i18n="reject_btn">Reject</span></button>
          </form>
        </div>
      }
      else
      {
        <div style="padding:1.5rem;">
          <span style="font-size:1rem;color:#27AE60;font-weight:600;"><i class="bi bi-check-circle-fill"></i> <span data-i18n="dtl_approved">Approved ✓</span></span>
        </div>
      }
    </div>
  </main>
</div>
